update() {
    echo "starting system updates..."
    local errors=()

    # ── macOS Software Updates ──────────────────────────────────────
    echo "\nchecking for macOS updates..."
    sudo softwareupdate -i -a || errors+=("macOS updates")

    # ── Homebrew ────────────────────────────────────────────────────
    echo "\nupdating Homebrew..."
    brew update                         || errors+=("brew update")
    brew upgrade                        || errors+=("brew upgrade")
    brew list --cask | while read -r cask; do
    brew upgrade --cask --greedy "$cask" 2>&1 \
        || echo "  ⚠️  skipped $cask (check manually)"
    done  # --greedy catches auto-update casks too

    echo "\ncleaning Homebrew..."
    brew cleanup --prune=all -s         # -s removes source files too
    brew autoremove
    brew doctor 2>&1 | grep -v "^Your system is ready" || true  # surface any issues

    # ── Trash ───────────────────────────────────────────────────────
    echo "\nemptying Trash..."
    rm -rf ~/.Trash/* 2>/dev/null

    # ── Logs ────────────────────────────────────────────────────────
    echo "\nclearing old logs..."
    sudo rm -rf /private/var/log/asl/*.asl 2>/dev/null
    rm -rf ~/Library/Logs/* 2>/dev/null

    # ── Summary ─────────────────────────────────────────────────────
    echo "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if [ ${#errors[@]} -eq 0 ]; then
        echo "✅ all updates and cleanup complete!"
    else
        echo "⚠️  completed with errors in: ${errors[*]}"
    fi

    # Show disk space freed
    echo "disk space available: $(df -h / | awk 'NR==2 {print $4}')"
}

# ============================================================================
# GIT ALIASES
# ============================================================================
alias gs="git status"
alias gd="git diff"
alias gw="git switch"
alias gco="git checkout"
alias gp="git push"
alias gpf="git push --force-with-lease"
alias gc="git commit"
alias gcs="git commit -s"
alias gcsn="git commit -s --no-verify"
alias gca="git commit --amend --no-edit"
alias gap="git add -p"
alias gfa="git fetch --all --prune"
alias glo="git log --oneline --decorate"
alias grbc="git rebase --continue"
alias gundo="git reset --soft HEAD~1"

# Enhanced git branch view with better formatting
alias gbr="git branch --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(contents:subject) %(color:green)(%(committerdate:relative)) [%(authorname)]' --sort=-committerdate"

# Delete merged/gone branches
alias gdbr="git fetch --prune && git branch -vv | grep ': gone]' | awk '{print \$1}' | xargs git branch -D"

# ============================================================================
# EDITOR ALIASES
# ============================================================================
alias n="nvim ."
alias nv="nvim"
alias vim="nvim"  # Use neovim instead of vim


# ============================================================================
# NETWORK MONITORING FUNCTIONS
# ============================================================================
listening() {
    if [ $# -eq 0 ]; then
        echo "🔍 showing all listening TCP ports:"
        sudo lsof -iTCP -sTCP:LISTEN -n -P | head -20
    elif [ $# -eq 1 ]; then
        echo "🔍 searching for TCP ports matching '$1':"
        sudo lsof -iTCP -sTCP:LISTEN -n -P | grep -i --color "$1"
    else
        echo "usage: listening [pattern]"
        echo "  listening        - show all listening TCP ports"
        echo "  listening 3000   - show processes listening on port 3000"
    fi
}

listening_udp() {
    if [ $# -eq 0 ]; then
        echo "🔍 showing all UDP connections:"
        sudo lsof -iUDP -n -P | head -20
    elif [ $# -eq 1 ]; then
        echo "🔍 searching for UDP connections matching '$1':"
        sudo lsof -iUDP -n -P | grep -i --color "$1"
    else
        echo "usage: listening_udp [pattern]"
        echo "  listening_udp        - show all UDP connections"
        echo "  listening_udp 53     - show UDP processes on port 53"
    fi
}

# Show what's using a specific port
port() {
    if [ $# -eq 1 ]; then
        echo "🔍 checking what's using port $1:"
        sudo lsof -i ":$1"
    else
        echo "usage: port <port_number>"
    fi
}

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================
# Quick directory creation and navigation
mkcd() {
    if [ $# -eq 1 ]; then
        mkdir -p "$1" && cd "$1"
        echo "📁 created and entered directory: $1"
    else
        echo "usage: mkcd <directory_name>"
    fi
}

# Find and kill processes (with confirmation)
pk() {
    if [ $# -eq 1 ]; then
        local pids=$(ps aux | grep "$1" | grep -v grep | awk '{print $2}')
        if [ -n "$pids" ]; then
            echo "🔍 found processes matching '$1':"
            ps aux | grep "$1" | grep -v grep
            echo -n "❓ kill these processes? (y/N): "
            read -r confirm
            if [[ $confirm =~ ^[Yy]$ ]]; then
                echo "$pids" | xargs kill -9
                echo "💀 processes killed"
            else
                echo "❌ cancelled"
            fi
        else
            echo "❌ no processes found matching '$1'"
        fi
    else
        echo "usage: pk <process_name>"
    fi
}

# Extract various archive formats
extract() {
    if [ $# -eq 1 ]; then
        if [ -f "$1" ]; then
            echo "📦 extracting $1..."
            case $1 in
                *.tar.bz2)   tar xjf "$1"     ;;
                *.tar.gz)    tar xzf "$1"     ;;
                *.bz2)       bunzip2 "$1"     ;;
                *.rar)       unrar e "$1"     ;;
                *.gz)        gunzip "$1"      ;;
                *.tar)       tar xf "$1"      ;;
                *.tbz2)      tar xjf "$1"     ;;
                *.tgz)       tar xzf "$1"     ;;
                *.zip)       unzip "$1"       ;;
                *.Z)         uncompress "$1"  ;;
                *.7z)        7z x "$1"        ;;
                *.xz)        unxz "$1"        ;;
                *.lzma)      unlzma "$1"      ;;
                *)           echo "❌ '$1' cannot be extracted (unsupported format)" ;;
            esac
            echo "✅ extraction complete"
        else
            echo "❌ '$1' is not a valid file"
        fi
    else
        echo "usage: extract <archive_file>"
    fi
}


